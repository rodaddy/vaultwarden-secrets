{
  "name": "vaultwarden-secrets",
  "version": "0.5.2",
  "description": "Secure secrets management library with Vaultwarden/Bitwarden CLI integration, macOS Keychain storage, and encrypted caching",
  "author": "Rico",
  "license": "MIT",
  "type": "module",
  "main": "index.ts",
  "types": "index.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/vaultwarden-secrets"
  },
  "keywords": [
    "vaultwarden",
    "bitwarden",
    "secrets",
    "password-manager",
    "keychain",
    "encryption",
    "aes-256-gcm",
    "cli",
    "typescript",
    "bun"
  ],
  "bin": {
    "secret": "./bin/secret"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "bun x tsc --noEmit",
    "example": "bun run example.ts",
    "secret": "bun run bin/secret",
    "install-config": "./install.sh",
    "install-pai": "./install.sh --pai",
    "uninstall": "./install.sh --uninstall",
    "set-session": "bun run cli.ts set-session",
    "get": "bun run cli.ts get"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "files": [
    "*.ts",
    "!*.test.ts",
    "!example.ts"
  ]
}
