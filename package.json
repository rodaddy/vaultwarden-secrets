{
  "name": "vaultwarden-secrets",
  "version": "0.5.2",
  "description": "Secure secrets management library with Vaultwarden/Bitwarden CLI integration, macOS Keychain storage, and encrypted caching",
  "author": "Rico",
  "license": "MIT",
  "type": "module",
  "main": "index.ts",
  "types": "index.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/rodaddy/vaultwarden-secrets"
  },
  "keywords": [
    "vaultwarden",
    "bitwarden",
    "secrets",
    "password-manager",
    "keychain",
    "encryption",
    "aes-256-gcm",
    "cli",
    "typescript",
    "bun"
  ],
  "bin": {
    "secret": "./bin/secret"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "bun x tsc --noEmit",
    "example": "bun run example.ts",
    "secret": "bun run bin/secret",
    "server": "bun run server/main.ts",
    "mcp": "bun run server/mcp.ts",
    "server:dev": "SECURITY_PROFILE=feeling-lucky bun run server/main.ts",
    "server:prod": "SECURITY_PROFILE=im-aware bun run server/main.ts",
    "install-config": "./install.sh",
    "install-pai": "./install.sh --pai",
    "uninstall": "./install.sh --uninstall",
    "set-session": "bun run cli.ts set-session",
    "get": "bun run cli.ts get",
    "cred-proxy": "bun run server/cred-proxy.ts",
    "identity": "bun run scripts/identity-admin.ts",
    "drift-check": "bun run scripts/drift-check.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "hono": "^4.11.7",
    "jose": "^6.1.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.0.0",
    "typedoc": "^0.28.16",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "files": [
    "*.ts",
    "!*.test.ts",
    "!example.ts"
  ]
}
