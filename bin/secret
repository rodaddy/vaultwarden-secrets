#!/usr/bin/env bun
/**
 * secret - CLI for vaultwarden-secrets
 *
 * Daily terminal commands for secrets management with muscle memory shortcuts.
 *
 * Usage:
 *   secret <path>                    Get secret (default action)
 *   secret get <path>                Get secret to stdout
 *   secret copy <path>               Copy secret to clipboard
 *   secret paste <path>              Set secret from clipboard
 *   secret set <path> [value]        Set secret (prompts if no value)
 *   secret list [filter]             List secrets
 *   secret search <query>            Fuzzy search secrets
 *   secret show <item>               Show all fields (tree view)
 *   secret vault list|use|current    Manage vaults
 *   secret folder [path|clear]       Set/show/clear folder prefix
 *   secret cache clear|stats         Manage cache
 *   secret migrate [paths...]        Migrate secrets from files to VW
 *   secret health                    Check connectivity
 *   secret version                   Show version
 *   secret help                      Show this help
 */

import { $ } from 'bun';
import * as readline from 'readline';
import {
  getSecret,
  getSecretObject,
  listSecrets,
  setSession,
  switchVault,
  getActiveVault,
  listVaults,
  clearCache,
  getCacheStats,
  getFolder,
  setFolder,
  clearFolder,
  SecretError,
  ErrorCode,
} from '../index';
import { getVaultSession } from '../keychain';
import { migrate } from '../migrate';

// =============================================================================
// Colors & Formatting
// =============================================================================

const green = (s: string) => `\x1b[32m${s}\x1b[0m`;
const red = (s: string) => `\x1b[31m${s}\x1b[0m`;
const yellow = (s: string) => `\x1b[33m${s}\x1b[0m`;
const cyan = (s: string) => `\x1b[36m${s}\x1b[0m`;
const dim = (s: string) => `\x1b[2m${s}\x1b[0m`;
const bold = (s: string) => `\x1b[1m${s}\x1b[0m`;

const VERSION = '0.1.0';

// =============================================================================
// Helpers
// =============================================================================

async function getClipboard(): Promise<string> {
  const result = await $`pbpaste`.quiet();
  return result.stdout.toString().trim();
}

async function setClipboard(value: string): Promise<void> {
  await $`printf '%s' ${value} | pbcopy`.quiet();
}

async function promptHidden(prompt: string): Promise<string> {
  return new Promise((resolve) => {
    process.stdout.write(prompt);
    const rl = readline.createInterface({
      input: process.stdin,
      output: process.stdout,
      terminal: true,
    });

    // Mute output for hidden input
    const originalWrite = (rl as any)._writeToOutput;
    (rl as any)._writeToOutput = () => {};

    rl.question('', (answer) => {
      (rl as any)._writeToOutput = originalWrite;
      rl.close();
      console.log(); // newline after hidden input
      resolve(answer);
    });
  });
}

function maskValue(value: string): string {
  if (value.length <= 4) return '••••';
  return '••••••••' + value.slice(-4);
}

// =============================================================================
// Command Handlers
// =============================================================================

async function handleGet(path: string): Promise<void> {
  const value = await getSecret(path);
  console.log(value);
}

async function handleCopy(path: string): Promise<void> {
  const value = await getSecret(path);
  await setClipboard(value);
  console.log(green('✓') + ` Copied ${cyan(path)} to clipboard`);
}

async function handlePaste(path: string): Promise<void> {
  const clipboard = await getClipboard();
  if (!clipboard) {
    console.error(red('Error:') + ' Clipboard is empty');
    process.exit(1);
  }

  // Parse path to get item and field
  const parts = path.split('.');
  const itemName = parts[0];

  // Get current vault session
  const vaultId = await getActiveVault();
  const session = await getVaultSession(vaultId);
  if (!session) {
    console.error(red('Error:') + ` No session for vault: ${vaultId}. Run: bw unlock`);
    process.exit(1);
  }

  try {
    // Get existing item
    const result = await $`BW_SESSION=${session} bw get item ${itemName}`.quiet();
    const item = JSON.parse(result.stdout.toString());

    // Determine which field to update
    if (parts.length === 1 || parts[1] === 'password') {
      // Update password field
      if (!item.login) item.login = {};
      item.login.password = clipboard;
    } else if (parts[1] === 'fields' && parts.length >= 3) {
      // Update custom field
      const fieldName = parts.slice(2).join('.');
      if (!item.fields) item.fields = [];
      const existingField = item.fields.find((f: any) => f.name === fieldName);
      if (existingField) {
        existingField.value = clipboard;
      } else {
        item.fields.push({ name: fieldName, value: clipboard, type: 0 });
      }
    } else {
      // Update nested field (e.g., login.username)
      const fieldPath = parts.slice(1);
      let current: any = item;
      for (let i = 0; i < fieldPath.length - 1; i++) {
        if (!current[fieldPath[i]]) current[fieldPath[i]] = {};
        current = current[fieldPath[i]];
      }
      current[fieldPath[fieldPath.length - 1]] = clipboard;
    }

    // Encode and save
    const encoded = Buffer.from(JSON.stringify(item)).toString('base64');
    await $`BW_SESSION=${session} bw edit item ${item.id} ${encoded}`.quiet();

    // Clear cache for this item
    await clearCache(vaultId);

    console.log(green('✓') + ` Updated ${cyan(path)} from clipboard`);
  } catch (error) {
    const message = error instanceof Error ? error.message : String(error);
    if (message.includes('not found')) {
      console.error(red('Error:') + ` Item not found: ${itemName}`);
      console.error(dim('Use Bitwarden web UI or CLI to create new items'));
    } else {
      console.error(red('Error:') + ` ${message}`);
    }
    process.exit(1);
  }
}

async function handleSet(path: string, value?: string): Promise<void> {
  // If no value provided, prompt for it
  const secretValue = value ?? await promptHidden('Enter value: ');

  if (!secretValue) {
    console.error(red('Error:') + ' No value provided');
    process.exit(1);
  }

  // Set clipboard temporarily and use paste logic
  await setClipboard(secretValue);
  await handlePaste(path);
}

async function handleList(filter?: string): Promise<void> {
  const secrets = await listSecrets(filter);

  if (secrets.length === 0) {
    if (filter) {
      console.log(yellow('No secrets matching:') + ` ${filter}`);
    } else {
      console.log(yellow('No secrets found'));
    }
    return;
  }

  for (const name of secrets) {
    console.log(name);
  }
}

async function handleSearch(query: string): Promise<void> {
  const secrets = await listSecrets();

  // Fuzzy search: score based on character matches
  const lowerQuery = query.toLowerCase();
  const scored = secrets
    .map((name) => {
      const lowerName = name.toLowerCase();
      let score = 0;
      let queryIdx = 0;

      // Simple fuzzy: check if query chars appear in order
      for (const char of lowerName) {
        if (queryIdx < lowerQuery.length && char === lowerQuery[queryIdx]) {
          score += 10;
          queryIdx++;
        }
      }

      // Bonus for substring match
      if (lowerName.includes(lowerQuery)) {
        score += 50;
      }

      // Bonus for prefix match
      if (lowerName.startsWith(lowerQuery)) {
        score += 100;
      }

      return { name, score, matched: queryIdx === lowerQuery.length };
    })
    .filter((item) => item.score > 0)
    .sort((a, b) => b.score - a.score);

  if (scored.length === 0) {
    console.log(yellow('No matches for:') + ` ${query}`);
    return;
  }

  for (const { name, matched } of scored.slice(0, 20)) {
    const prefix = matched ? green('●') : dim('○');
    console.log(`${prefix} ${name}`);
  }

  if (scored.length > 20) {
    console.log(dim(`  ... and ${scored.length - 20} more`));
  }
}

async function handleShow(itemName: string): Promise<void> {
  const obj = await getSecretObject(itemName);
  const keys = Object.keys(obj);

  console.log(bold(itemName));

  keys.forEach((key, idx) => {
    const isLast = idx === keys.length - 1;
    const prefix = isLast ? '└─' : '├─';
    const value = key.toLowerCase().includes('password') || key.toLowerCase().includes('secret') || key.toLowerCase().includes('token')
      ? maskValue(obj[key])
      : obj[key];

    console.log(`${prefix} ${cyan(key)}: ${value}`);
  });
}

async function handleVault(subcommand?: string, arg?: string): Promise<void> {
  switch (subcommand) {
    case 'list': {
      const vaults = await listVaults();
      const activeVault = await getActiveVault();

      if (vaults.length === 0) {
        console.log(yellow('No vaults configured'));
        console.log(dim('Use "secret set-session <vault> <token>" to add a vault'));
        return;
      }

      console.log(bold('Vaults:'));
      for (const vault of vaults) {
        const isActive = vault.name === activeVault;
        const marker = isActive ? green(' ← active') : '';
        const prefix = isActive ? green('●') : dim('○');
        console.log(`  ${prefix} ${vault.name}${marker}`);
        if (vault.description) {
          console.log(`    ${dim(vault.description)}`);
        }
      }
      break;
    }

    case 'use': {
      if (!arg) {
        console.error(red('Usage:') + ' secret vault use <name>');
        process.exit(1);
      }
      await switchVault(arg);
      console.log(green('✓') + ` Switched to vault: ${cyan(arg)}`);
      console.log(dim('  Cache cleared for new vault context'));
      break;
    }

    case 'current': {
      const active = await getActiveVault();
      console.log(active);
      break;
    }

    default: {
      console.log(`
${bold('Vault Commands:')}
  secret vault list              List available vaults
  secret vault use <name>        Switch active vault
  secret vault current           Show current vault
`);
    }
  }
}

async function handleFolder(subcommand?: string): Promise<void> {
  switch (subcommand) {
    case 'clear': {
      await clearFolder();
      console.log(green('✓') + ' Folder prefix cleared');
      console.log(dim('  Secrets will now be looked up by exact path'));
      break;
    }

    case undefined: {
      // No subcommand = show current folder
      const folder = await getFolder();
      if (folder) {
        console.log(folder);
      } else {
        console.log(dim('(no folder set)'));
      }
      break;
    }

    default: {
      // Treat as folder to set
      await setFolder(subcommand);
      console.log(green('✓') + ` Folder set: ${cyan(subcommand)}`);
      console.log(dim(`  "secret get X" now looks up "${subcommand}/X"`));
      break;
    }
  }
}

async function handleCache(subcommand?: string): Promise<void> {
  switch (subcommand) {
    case 'clear': {
      await clearCache();
      console.log(green('✓') + ' Cache cleared');
      break;
    }

    case 'stats': {
      const stats = getCacheStats();
      console.log(bold('Cache Statistics:'));
      console.log(`  Entries:     ${stats.entries}/${stats.maxSize}`);
      console.log(`  Hit Rate:    ${(stats.hitRate * 100).toFixed(1)}%`);
      console.log(`  Hits:        ${green(String(stats.hits))}`);
      console.log(`  Misses:      ${yellow(String(stats.misses))}`);
      console.log(`  Evictions:   ${stats.evictions}`);
      console.log(`  Expirations: ${stats.expirations}`);
      if (stats.vaults.length > 0) {
        console.log(`  Vaults:      ${stats.vaults.join(', ')}`);
      }
      break;
    }

    case 'refresh': {
      await clearCache();
      // Pre-warm by listing (triggers cache population on next access)
      console.log(green('✓') + ' Cache refreshed');
      break;
    }

    default: {
      console.log(`
${bold('Cache Commands:')}
  secret cache clear             Clear all cached secrets
  secret cache stats             Show cache statistics
  secret cache refresh           Force refresh from Vaultwarden
`);
    }
  }
}

async function handleHealth(): Promise<void> {
  console.log(bold('Health Check\n'));

  // Check bw CLI
  process.stdout.write('  Bitwarden CLI: ');
  try {
    const result = await $`bw --version`.quiet();
    console.log(green('✓') + ` v${result.stdout.toString().trim()}`);
  } catch {
    console.log(red('✗') + ' Not installed');
    console.log(dim('    Install: brew install bitwarden-cli'));
    process.exit(1);
  }

  // Check active vault session
  const vaultId = await getActiveVault();
  process.stdout.write(`  Vault (${vaultId}): `);
  const session = await getVaultSession(vaultId);
  if (!session) {
    console.log(red('✗') + ' No session');
    console.log(dim('    Run: bw unlock'));
    process.exit(1);
  }

  // Check session validity
  try {
    await $`BW_SESSION=${session} bw sync`.quiet();
    console.log(green('✓') + ' Session valid');
  } catch {
    console.log(yellow('⚠') + ' Session may be expired');
    console.log(dim('    Run: bw unlock'));
  }

  // Check cache
  process.stdout.write('  Cache: ');
  const stats = getCacheStats();
  console.log(green('✓') + ` ${stats.entries} entries, ${(stats.hitRate * 100).toFixed(0)}% hit rate`);

  console.log(green('\n✓ System healthy'));
}

async function handleSetSession(vault: string, token: string): Promise<void> {
  await setSession(vault, token);
  console.log(green('✓') + ` Session stored for vault '${vault}'`);
}

function showHelp(): void {
  console.log(`
${bold('secret')} - Vaultwarden secrets CLI v${VERSION}

${bold('USAGE:')}
  secret <path>                    Get secret (shorthand)
  secret <command> [args]          Run command

${bold('DAILY COMMANDS:')}
  ${cyan('get')} <path>                   Retrieve secret to stdout
  ${cyan('copy')} <path>                  Copy secret to clipboard
  ${cyan('paste')} <path>                 Set secret from clipboard
  ${cyan('set')} <path> [value]           Set secret (prompts if no value)

${bold('DISCOVERY:')}
  ${cyan('list')} [filter]                List secrets (optional filter)
  ${cyan('search')} <query>               Fuzzy search secrets
  ${cyan('show')} <item>                  Show all fields (tree view)

${bold('VAULT MANAGEMENT:')}
  ${cyan('vault')} list                   List available vaults
  ${cyan('vault')} use <name>             Switch active vault
  ${cyan('vault')} current                Show current vault

${bold('FOLDER PREFIX:')}
  ${cyan('folder')}                       Show current folder
  ${cyan('folder')} <path>                Set folder prefix
  ${cyan('folder')} clear                 Clear folder prefix

${bold('CACHE MANAGEMENT:')}
  ${cyan('cache')} clear                  Clear cached secrets
  ${cyan('cache')} stats                  Show cache statistics
  ${cyan('cache')} refresh                Force refresh from VW

${bold('MIGRATION:')}
  ${cyan('migrate')} [paths...]           Scan and migrate secrets to VW
                               Interactive wizard for .env, shell configs, scripts

${bold('SYSTEM:')}
  ${cyan('health')}                       Check connectivity & session
  ${cyan('set-session')} <vault> <token>  Store BW session token
  ${cyan('version')}                      Show version
  ${cyan('help')}                         Show this help

${bold('EXAMPLES:')}
  secret github-pat                Get password from github-pat item
  secret github-pat.login.username Get username field
  secret copy "API Keys.GEMINI"    Copy to clipboard
  secret set my-secret             Prompt for hidden value
  secret search postgres           Fuzzy search for "postgres"
  secret show "PostgreSQL clawdbot" Show all fields

${bold('PATH SYNTAX:')}
  Item                             Get password field (default)
  Item.field                       Get specific field
  Item.login.username              Get nested field
  Item.fields.CUSTOM_FIELD         Get custom field
`);
}

// =============================================================================
// Main
// =============================================================================

const COMMANDS = [
  'get', 'copy', 'paste', 'set',
  'list', 'search', 'show',
  'vault', 'folder', 'cache', 'migrate', 'health',
  'set-session', 'version', 'help', '--help'
];

async function main(): Promise<void> {
  const args = process.argv.slice(2);
  const command = args[0];
  const restArgs = args.slice(1);

  try {
    // No args = show help
    if (!command) {
      showHelp();
      return;
    }

    // Check if command is a known command or treat as path
    if (!COMMANDS.includes(command)) {
      // Treat as path for get
      await handleGet(command);
      return;
    }

    switch (command) {
      case 'get':
        if (!restArgs[0]) {
          console.error(red('Usage:') + ' secret get <path>');
          process.exit(1);
        }
        await handleGet(restArgs[0]);
        break;

      case 'copy':
        if (!restArgs[0]) {
          console.error(red('Usage:') + ' secret copy <path>');
          process.exit(1);
        }
        await handleCopy(restArgs[0]);
        break;

      case 'paste':
        if (!restArgs[0]) {
          console.error(red('Usage:') + ' secret paste <path>');
          process.exit(1);
        }
        await handlePaste(restArgs[0]);
        break;

      case 'set':
        if (!restArgs[0]) {
          console.error(red('Usage:') + ' secret set <path> [value]');
          process.exit(1);
        }
        await handleSet(restArgs[0], restArgs[1]);
        break;

      case 'list':
        await handleList(restArgs[0]);
        break;

      case 'search':
        if (!restArgs[0]) {
          console.error(red('Usage:') + ' secret search <query>');
          process.exit(1);
        }
        await handleSearch(restArgs[0]);
        break;

      case 'show':
        if (!restArgs[0]) {
          console.error(red('Usage:') + ' secret show <item>');
          process.exit(1);
        }
        await handleShow(restArgs[0]);
        break;

      case 'vault':
        await handleVault(restArgs[0], restArgs[1]);
        break;

      case 'folder':
        await handleFolder(restArgs[0]);
        break;

      case 'cache':
        await handleCache(restArgs[0]);
        break;

      case 'migrate':
        await migrate({
          paths: restArgs.length > 0 ? restArgs : undefined,
          interactive: true,
        });
        break;

      case 'health':
        await handleHealth();
        break;

      case 'set-session':
        if (!restArgs[0] || !restArgs[1]) {
          console.error(red('Usage:') + ' secret set-session <vault> <token>');
          process.exit(1);
        }
        await handleSetSession(restArgs[0], restArgs[1]);
        break;

      case 'version':
        console.log(`secret v${VERSION}`);
        break;

      case 'help':
      case '--help':
        showHelp();
        break;

      default:
        console.error(red('Unknown command:') + ` ${command}`);
        console.error(dim('Run "secret help" for usage'));
        process.exit(1);
    }
  } catch (error) {
    if (error instanceof SecretError) {
      console.error(red('Error:') + ` ${error.message}`);
      if (error.code === ErrorCode.VAULT_LOCKED) {
        console.error(dim('Run: bw unlock'));
      }
    } else {
      console.error(red('Error:') + ` ${error instanceof Error ? error.message : String(error)}`);
    }
    process.exit(1);
  }
}

main();
