# Vaultwarden Secrets Server - Environment Variables
# Copy to /opt/vaultwarden-secrets/.env or set in systemd service

# =============================================================================
# Security Profile (Choose one)
# =============================================================================
# feeling-lucky: No auth, auto IP whitelist (DEV ONLY)
# im-aware:      Bearer token, auto IP whitelist (RECOMMENDED for homelab)
# im-a-dev:      OAuth2, auto IP whitelist (Production web apps)
# openclaw:      mTLS + JWT, 127.0.0.1 only (Maximum security)

SECURITY_PROFILE=im-aware

# =============================================================================
# Server Configuration
# =============================================================================
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# =============================================================================
# API Tokens (Required for im-aware profile)
# =============================================================================
# Format: API_TOKEN_<CLIENT_NAME>=<token>
# Generate tokens: openssl rand -hex 32

API_TOKEN_LXC200=your-secret-token-for-postgres
API_TOKEN_LXC202=your-secret-token-for-n8n
# API_TOKEN_NGINX=your-secret-token-for-nginx
# API_TOKEN_GRAFANA=your-secret-token-for-grafana

# =============================================================================
# IP Whitelist Override (Optional)
# =============================================================================
# By default, auto-detects local network (/24)
# Override with comma-separated CIDR ranges:
# IP_WHITELIST=10.0.0.0/8,172.17.0.0/16,192.168.0.0/16

# =============================================================================
# OAuth2 Configuration (Required for im-a-dev profile)
# =============================================================================
# OAUTH_PROVIDER=google
# OAUTH_CLIENT_ID=your-client-id
# OAUTH_CLIENT_SECRET=your-client-secret
# OAUTH_CALLBACK_URL=https://secrets.rodaddy.live/auth/callback

# =============================================================================
# mTLS Configuration (Required for openclaw profile)
# =============================================================================
# Certificate fingerprint allowlist
ALLOWED_CLIENT_CERTS=/opt/vaultwarden-secrets/certs.json
# Or inline: ALLOWED_CERT_FINGERPRINTS=sha256:abc...,sha256:def...

# mTLS mode: direct (Bun TLS) or proxy (nginx/haproxy validates cert)
MTLS_MODE=proxy

# Header name for proxy mode (nginx sets this after validating cert)
MTLS_HEADER=X-Client-Cert-Fingerprint

# TLS certificates for direct mode (Bun.serve with TLS)
# TLS_CERT=/opt/vaultwarden-secrets/tls/server.crt
# TLS_KEY=/opt/vaultwarden-secrets/tls/server.key
# TLS_CA=/opt/vaultwarden-secrets/tls/ca.crt

# JWT secret for token signing (CHANGE IN PRODUCTION)
JWT_SECRET=change-this-to-a-secure-random-value-in-production

# =============================================================================
# Vaultwarden CLI Configuration
# =============================================================================
# Required: Set via `bw config server <url>` or environment
# BW_CLIENTID=user.your-client-id
# BW_CLIENTSECRET=your-client-secret
# BW_PASSWORD=your-master-password

# =============================================================================
# Audit Logging (Optional)
# =============================================================================
# AUDIT_LOG_PATH=/var/log/vaultwarden-secrets/audit.log
# AUDIT_LOG_LEVEL=info
