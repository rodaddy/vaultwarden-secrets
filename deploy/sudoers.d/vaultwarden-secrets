# vaultwarden-secrets — scoped NOPASSWD grant for the deploy operator.
#
# LEAST PRIVILEGE. Deploys run as the operator user `rico` (uid 3000), NOT root.
# deploy/deploy.sh routes every privileged action through run_privileged(),
# which prefixes `sudo -n` (non-interactive). This file is the COMPLETE set of
# commands that operator may run without a password — nothing else. There is no
# root shell here and no blanket `ALL` grant.
#
# Install:
#   install -m 0440 -o root -g root \
#     deploy/sudoers.d/vaultwarden-secrets /etc/sudoers.d/vaultwarden-secrets
#   visudo -cf /etc/sudoers.d/vaultwarden-secrets   # validate before trusting it
#
# Sudoers matching gotcha (honored below):
#   - WRITE verbs (start/stop/restart) are EXACT-match: no trailing wildcard on
#     the verb, so the operator can only act on the named units and cannot smuggle
#     extra flags/units. daemon-reload is likewise exact.
#   - READ commands (status/is-active/journalctl) carry a trailing ` *` so flags
#     like `--no-pager` / `--quiet` still match. A bare rule would NOT match
#     `systemctl status foo.service --no-pager`.
#
# The service ACCOUNT `vaultwarden-secrets` (group ai-services) is provisioned
# UPSTREAM (TN01/rtech-infra); this grant only lets the operator install units,
# manage the services, and probe/readback state on the host.

# --- exact write verbs: manage exactly the vaultwarden-secrets units ---------
rico ALL=(root) NOPASSWD: /usr/bin/systemctl start vaultwarden-secrets.service, \
                          /usr/bin/systemctl stop vaultwarden-secrets.service, \
                          /usr/bin/systemctl restart vaultwarden-secrets.service, \
                          /usr/bin/systemctl start vaultwarden-secrets-mcp.service, \
                          /usr/bin/systemctl stop vaultwarden-secrets-mcp.service, \
                          /usr/bin/systemctl restart vaultwarden-secrets-mcp.service, \
                          /usr/bin/systemctl start vw-cred-proxy.service, \
                          /usr/bin/systemctl stop vw-cred-proxy.service, \
                          /usr/bin/systemctl restart vw-cred-proxy.service, \
                          /usr/bin/systemctl start vw-snapshot.service, \
                          /usr/bin/systemctl stop vw-snapshot.service, \
                          /usr/bin/systemctl restart vw-snapshot.service, \
                          /usr/bin/systemctl start vw-snapshot.timer, \
                          /usr/bin/systemctl stop vw-snapshot.timer, \
                          /usr/bin/systemctl restart vw-snapshot.timer, \
                          /usr/bin/systemctl start vw-session-refresh.service, \
                          /usr/bin/systemctl stop vw-session-refresh.service, \
                          /usr/bin/systemctl restart vw-session-refresh.service, \
                          /usr/bin/systemctl start vw-session-refresh.timer, \
                          /usr/bin/systemctl stop vw-session-refresh.timer, \
                          /usr/bin/systemctl restart vw-session-refresh.timer, \
                          /usr/bin/systemctl start vw-backup.service, \
                          /usr/bin/systemctl stop vw-backup.service, \
                          /usr/bin/systemctl restart vw-backup.service, \
                          /usr/bin/systemctl start vw-backup.timer, \
                          /usr/bin/systemctl stop vw-backup.timer, \
                          /usr/bin/systemctl restart vw-backup.timer

# --- enable/disable the same units (unit install/retirement) ------------------
rico ALL=(root) NOPASSWD: /usr/bin/systemctl enable vaultwarden-secrets.service, \
                          /usr/bin/systemctl disable vaultwarden-secrets.service, \
                          /usr/bin/systemctl enable vaultwarden-secrets-mcp.service, \
                          /usr/bin/systemctl disable vaultwarden-secrets-mcp.service, \
                          /usr/bin/systemctl enable vw-cred-proxy.service, \
                          /usr/bin/systemctl disable vw-cred-proxy.service, \
                          /usr/bin/systemctl enable vw-snapshot.timer, \
                          /usr/bin/systemctl disable vw-snapshot.timer, \
                          /usr/bin/systemctl enable vw-session-refresh.timer, \
                          /usr/bin/systemctl disable vw-session-refresh.timer, \
                          /usr/bin/systemctl enable vw-backup.timer, \
                          /usr/bin/systemctl disable vw-backup.timer

# --- retire the removed unauthenticated deploy trigger (exact) ----------------
# deploy.sh does `systemctl disable --now vw-deploy-webhook.service`.
rico ALL=(root) NOPASSWD: /usr/bin/systemctl disable --now vw-deploy-webhook.service, \
                          /usr/bin/systemctl stop vw-deploy-webhook.service

# --- daemon-reload (exact; privileged, no flags) ------------------------------
rico ALL=(root) NOPASSWD: /usr/bin/systemctl daemon-reload

# --- reads: status / is-active carry a trailing ` *` for flags ----------------
rico ALL=(root) NOPASSWD: /usr/bin/systemctl status vaultwarden-secrets* *, \
                          /usr/bin/systemctl is-active vaultwarden-secrets* *, \
                          /usr/bin/systemctl status vw-* *, \
                          /usr/bin/systemctl is-active vw-* *

# --- journal reads: trailing ` *` allows --no-pager / -u expansion ------------
rico ALL=(root) NOPASSWD: /usr/bin/journalctl -u vaultwarden* *, \
                          /usr/bin/journalctl -u vw-* *

# --- unit install + backup + retirement file ops in /etc/systemd/system -------
# deploy.sh uses `install -m 0644 <src> <dst>` for unit swaps/backups/restores,
# `mkdir -p` / `rm -rf` for the backup dir, and `rm -f` for retired units.
rico ALL=(root) NOPASSWD: /usr/bin/install -m 0644 * /etc/systemd/system/*, \
                          /usr/bin/mkdir -p /etc/systemd/system/.vw-backup, \
                          /usr/bin/rm -rf /etc/systemd/system/.vw-backup, \
                          /usr/bin/rm -f /etc/systemd/system/*.service

# --- read a path AS the service user (preflight readable_by) ------------------
# deploy.sh readable_by() runs `sudo -n -u <service-user> test -r <path>` to
# prove the hardened unit's User= can read its session/key/env files.
rico ALL=(vaultwarden-secrets) NOPASSWD: /usr/bin/test -r /var/lib/vaultwarden-secrets/*, \
                                         /usr/bin/test -r /opt/vaultwarden-secrets/*

# --- install/chown into the service state dir (upstream owns the account) ------
# Any relocation/re-own of state files the deploy performs is scoped to
# /var/lib/vaultwarden-secrets and owned by the upstream-provisioned service user.
rico ALL=(root) NOPASSWD: /usr/bin/install -d -m 0700 -o vaultwarden-secrets -g ai-services /var/lib/vaultwarden-secrets/*, \
                          /usr/bin/chown -R vaultwarden-secrets\:ai-services /var/lib/vaultwarden-secrets/*, \
                          /usr/bin/chown vaultwarden-secrets\:ai-services /var/lib/vaultwarden-secrets/*
