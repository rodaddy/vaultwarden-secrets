# vaultwarden-secrets — scoped NOPASSWD grant for the deploy operator.
#
# LEAST PRIVILEGE. Deploys run as the operator user `rico` (uid 3000), NOT root.
# deploy/deploy.sh routes every privileged action through run_privileged(),
# which prefixes `sudo -n` (non-interactive) and FAILS CLOSED — it returns
# sudo's real exit code, so a denied grant aborts the deploy (never proceeds).
# This file is the COMPLETE set of commands that operator may run without a
# password. There is no root shell and no blanket `ALL`.
#
# HARDENING (security review of fix/deroot-deploy):
#   - NO wildcard install into /etc/systemd/system. Every install rule names the
#     EXACT source path (pinned under /opt/vaultwarden-secrets/deploy/systemd or
#     the backup dir) AND the EXACT destination filename. An operator cannot
#     supply an arbitrary source or a traversal-crafted destination (P0-2).
#   - NO `rm -f *.service` wildcard. Deletion is enumerated to this app's own
#     units + the retired webhook only (P1-4).
#   - NO `chown -R .../*` glob. Directory creation/ownership uses `install -d`
#     against the fixed state dir + named subdirs, no `-R`, no `..` traversal
#     surface (P1-3).
#   - Reads (is-active) are the EXACT invocation deploy.sh makes, not a
#     unit-prefix + trailing-` *` that could smuggle a different target (P1-5).
#
# Install & validate:
#   install -m 0440 -o root -g root \
#     deploy/sudoers.d/vaultwarden-secrets /etc/sudoers.d/vaultwarden-secrets
#   visudo -cf /etc/sudoers.d/vaultwarden-secrets   # must print "parsed OK"
#
# The service ACCOUNT `mcp2cli` (group ai-services) is provisioned
# UPSTREAM (TN01/rtech-infra); this grant never creates it.

# Pin the deploy checkout. deploy.sh's REPO_DIR default is /opt/vaultwarden-secrets;
# unit sources live under $REPO_DIR/deploy/systemd. These rules assume that path.
Cmnd_Alias VWS_UNIT_INSTALL = \
  /usr/bin/install -m 0644 /opt/vaultwarden-secrets/deploy/systemd/vaultwarden-secrets.service /etc/systemd/system/vaultwarden-secrets.service, \
  /usr/bin/install -m 0644 /opt/vaultwarden-secrets/deploy/systemd/vaultwarden-secrets-mcp.service /etc/systemd/system/vaultwarden-secrets-mcp.service, \
  /usr/bin/install -m 0644 /opt/vaultwarden-secrets/deploy/systemd/vw-cred-proxy.service /etc/systemd/system/vw-cred-proxy.service, \
  /usr/bin/install -m 0644 /opt/vaultwarden-secrets/deploy/systemd/vw-snapshot.service /etc/systemd/system/vw-snapshot.service, \
  /usr/bin/install -m 0644 /opt/vaultwarden-secrets/deploy/systemd/vw-backup.service /etc/systemd/system/vw-backup.service, \
  /usr/bin/install -m 0644 /opt/vaultwarden-secrets/deploy/systemd/vw-deploy.service /etc/systemd/system/vw-deploy.service

# Backup: copy the live unit into the backup dir (deploy.sh backup_unit).
Cmnd_Alias VWS_UNIT_BACKUP = \
  /usr/bin/install -m 0644 /etc/systemd/system/vaultwarden-secrets.service /etc/systemd/system/.vw-backup/vaultwarden-secrets.service, \
  /usr/bin/install -m 0644 /etc/systemd/system/vaultwarden-secrets-mcp.service /etc/systemd/system/.vw-backup/vaultwarden-secrets-mcp.service, \
  /usr/bin/install -m 0644 /etc/systemd/system/vw-cred-proxy.service /etc/systemd/system/.vw-backup/vw-cred-proxy.service, \
  /usr/bin/install -m 0644 /etc/systemd/system/vw-snapshot.service /etc/systemd/system/.vw-backup/vw-snapshot.service, \
  /usr/bin/install -m 0644 /etc/systemd/system/vw-backup.service /etc/systemd/system/.vw-backup/vw-backup.service, \
  /usr/bin/install -m 0644 /etc/systemd/system/vw-deploy.service /etc/systemd/system/.vw-backup/vw-deploy.service

# Restore: copy a backed-up unit back into place (deploy.sh restore_unit).
Cmnd_Alias VWS_UNIT_RESTORE = \
  /usr/bin/install -m 0644 /etc/systemd/system/.vw-backup/vaultwarden-secrets.service /etc/systemd/system/vaultwarden-secrets.service, \
  /usr/bin/install -m 0644 /etc/systemd/system/.vw-backup/vaultwarden-secrets-mcp.service /etc/systemd/system/vaultwarden-secrets-mcp.service, \
  /usr/bin/install -m 0644 /etc/systemd/system/.vw-backup/vw-cred-proxy.service /etc/systemd/system/vw-cred-proxy.service, \
  /usr/bin/install -m 0644 /etc/systemd/system/.vw-backup/vw-snapshot.service /etc/systemd/system/vw-snapshot.service, \
  /usr/bin/install -m 0644 /etc/systemd/system/.vw-backup/vw-backup.service /etc/systemd/system/vw-backup.service, \
  /usr/bin/install -m 0644 /etc/systemd/system/.vw-backup/vw-deploy.service /etc/systemd/system/vw-deploy.service

# Backup dir lifecycle: exact fixed path, no wildcard.
Cmnd_Alias VWS_BACKUP_DIR = \
  /usr/bin/mkdir -p /etc/systemd/system/.vw-backup, \
  /usr/bin/rm -rf /etc/systemd/system/.vw-backup

# Unit deletion: ONLY this app's own units + the retired webhook. No wildcard.
Cmnd_Alias VWS_UNIT_RM = \
  /usr/bin/rm -f /etc/systemd/system/vaultwarden-secrets.service, \
  /usr/bin/rm -f /etc/systemd/system/vaultwarden-secrets-mcp.service, \
  /usr/bin/rm -f /etc/systemd/system/vw-cred-proxy.service, \
  /usr/bin/rm -f /etc/systemd/system/vw-snapshot.service, \
  /usr/bin/rm -f /etc/systemd/system/vw-backup.service, \
  /usr/bin/rm -f /etc/systemd/system/vw-deploy.service, \
  /usr/bin/rm -f /etc/systemd/system/vw-deploy-webhook.service

# daemon-reload (exact, no flags).
Cmnd_Alias VWS_RELOAD = /usr/bin/systemctl daemon-reload

# The EXACT systemctl invocations deploy.sh makes — no unit-prefix wildcards,
# no trailing ` *`. Retirement, the protected-MCP restart, the rollback stop,
# and the is-active health probe (with its literal --quiet flag).
Cmnd_Alias VWS_DEPLOY_SYSTEMCTL = \
  /usr/bin/systemctl disable --now vw-deploy-webhook.service, \
  /usr/bin/systemctl restart vaultwarden-secrets-mcp.service, \
  /usr/bin/systemctl stop vaultwarden-secrets-mcp.service, \
  /usr/bin/systemctl is-active --quiet vaultwarden-secrets-mcp.service

# Operator lifecycle beyond deploy.sh: exact verbs on exact units (no wildcards,
# no flags). Kept minimal — start/stop/restart the app's own services + timers.
Cmnd_Alias VWS_OPERATOR_SYSTEMCTL = \
  /usr/bin/systemctl start vaultwarden-secrets.service, \
  /usr/bin/systemctl stop vaultwarden-secrets.service, \
  /usr/bin/systemctl restart vaultwarden-secrets.service, \
  /usr/bin/systemctl start vaultwarden-secrets-mcp.service, \
  /usr/bin/systemctl start vw-cred-proxy.service, \
  /usr/bin/systemctl stop vw-cred-proxy.service, \
  /usr/bin/systemctl restart vw-cred-proxy.service, \
  /usr/bin/systemctl start vw-snapshot.timer, \
  /usr/bin/systemctl stop vw-snapshot.timer, \
  /usr/bin/systemctl restart vw-snapshot.timer, \
  /usr/bin/systemctl start vw-backup.timer, \
  /usr/bin/systemctl stop vw-backup.timer, \
  /usr/bin/systemctl restart vw-backup.timer, \
  /usr/bin/systemctl enable vw-snapshot.timer, \
  /usr/bin/systemctl disable vw-snapshot.timer, \
  /usr/bin/systemctl enable vw-backup.timer, \
  /usr/bin/systemctl disable vw-backup.timer

# State dir creation/ownership: `install -d` against the FIXED dir + named
# subdirs only. No `chown -R`, no `..` traversal surface, no glob.
Cmnd_Alias VWS_STATE_DIR = \
  /usr/bin/install -d -m 0700 -o mcp2cli -g ai-services /var/lib/vaultwarden-secrets, \
  /usr/bin/install -d -m 0700 -o mcp2cli -g ai-services /var/lib/vaultwarden-secrets/state, \
  /usr/bin/install -d -m 0700 -o mcp2cli -g ai-services /var/lib/vaultwarden-secrets/config

# Read a path AS the service user (deploy.sh readable_by preflight). Exact fixed
# roots; runs as the service user, cannot escalate.
Cmnd_Alias VWS_READ_AS_USER = \
  /usr/bin/test -r /var/lib/vaultwarden-secrets, \
  /usr/bin/test -r /var/lib/vaultwarden-secrets/.bw-session, \
  /usr/bin/test -r /var/lib/vaultwarden-secrets/.master-key, \
  /usr/bin/test -r /var/lib/vaultwarden-secrets/audit.log, \
  /usr/bin/test -r /var/lib/vaultwarden-secrets/state, \
  /usr/bin/test -r /var/lib/vaultwarden-secrets/config, \
  /usr/bin/test -r /opt/vaultwarden-secrets/.env, \
  /usr/bin/test -r /opt/vaultwarden-secrets/.env.cred-proxy

rico ALL=(root) NOPASSWD: VWS_UNIT_INSTALL, VWS_UNIT_BACKUP, VWS_UNIT_RESTORE, \
                          VWS_BACKUP_DIR, VWS_UNIT_RM, VWS_RELOAD, \
                          VWS_DEPLOY_SYSTEMCTL, VWS_OPERATOR_SYSTEMCTL, \
                          VWS_STATE_DIR
rico ALL=(mcp2cli) NOPASSWD: VWS_READ_AS_USER
